[{"title":{"ja":"\u3010\u30a2\u30c3\u30d7\u30c7\u30fc\u30c8\u306e\u304a\u77e5\u3089\u305b\u3011","ko":"\u3010\uc5c5\ub370\uc774\ud2b8 \uc548\ub0b4\u3011","en":"\u3010Update Notice\u3011","zh-TW":"\u3010\u66f4\u65b0\u516c\u544a\u3011"},"content":{"ja":"8\u670811\u65e5\uff08\u6708\uff09\u306b\u30a2\u30c3\u30d7\u30c7\u30fc\u30c8\u3092\u5b9f\u65bd\u3044\u305f\u3057\u307e\u3057\u305f\u3002\u66f4\u65b0\u5185\u5bb9\u306f\u4ee5\u4e0b\u306e\u901a\u308a\u3067\u3059\u3002\r\n\u3010\u65b0\u30a4\u30d9\u30f3\u30c8\u3011\r\n\u300e\u5b66\u5712\u9ed9\u793a\u9332 HIGHSCHOOL OF THE DEAD\u300f\u3068\u306e\u30b3\u30e9\u30dc\u30a4\u30d9\u30f3\u30c8\u524d\u7de8\u958b\u50ac\uff01\r\n\r\n\u30fb\u65b0\u30b3\u30e9\u30dc\u4e3b\u4eba\u516c\u300c\u5bae\u672c\u9e97\u300d\u767b\u5834\uff01\r\n\u3000\u5165\u624b\u3059\u308b\u3053\u3068\u3067\u5357\u96f2\u30cf\u30b8\u30e1\u3068\u4e3b\u4eba\u516c\u306e\u5207\u308a\u66ff\u3048\u304c\u53ef\u80fd\u306b\u306a\u308a\u307e\u3059\u3002\r\n\u30fb\u65b0\u9b54\u7363\u300c\u30b3\u30e9\u30dc\u9b54\u7363\u30b8\u30fc\u30af\u300d\uff08SSR\/UR\/UR+\uff09\u304c\u30a4\u30d9\u30f3\u30c8\u306b\u767b\u5834\uff01\r\n\u30fb\u65b0\u82f1\u96c4\u300c\u6bd2\u5cf6\u51b4\u5b50\u300d\u304c\u30ac\u30c1\u30e3\u306b\u767b\u5834\uff01\r\n\u30fb\u65b0\u9b54\u6cd5\u9663\u300c\u30be\u30f3\u30d3\u9b54\u6cd5\u9663\u300d\u304c\u30ac\u30c1\u30e3\u306b\u767b\u5834\uff01\r\n\u30fb\u65b0\u30b9\u30ad\u30f3\u300c\u6bd2\u5cf6\u51b4\u5b50 - \u6c34\u7740\u300d\u304c\u30d1\u30ba\u30eb\u30a4\u30d9\u30f3\u30c8\u306b\u767b\u5834\uff01\r\n\u30fb\u65b0\u30a2\u30fc\u30c6\u30a3\u30d5\u30a1\u30af\u30c8\u300c\u96fb\u52d5\u30c9\u30ea\u30eb\u300d\u304c\u30ac\u30c1\u30e3\u306b\u767b\u5834\uff01\r\n\u30fb\u65b0\u30d5\u30ec\u30fc\u30e0\u300c\u81f3\u9ad8\u306e\u5263\u300d\u304c\u80b2\u6210\u30d1\u30c3\u30af\u3067\u767b\u5834\uff01\r\n\u30fb\u65b0\u79f0\u53f7\u300c\u81f3\u9ad8\u306e\u5263\u300d\u304c\u80b2\u6210\u30d1\u30c3\u30af\u3067\u767b\u5834\uff01\r\n\u30fb\u65b0\u3075\u304d\u3060\u3057\u300c\u81f3\u9ad8\u306e\u5263\u300d\u304c\u30d1\u30b9\u5831\u916c\u306b\u767b\u5834\uff01\r\n\u30fb\u65b0\u30d5\u30ec\u30fc\u30e0\u300c\u9ed9\u793a\u9332\u306e\u8987\u8005\u300d\u304c\u500b\u4eba\u30e9\u30f3\u30ad\u30f3\u30b0\u5831\u916c\u306b\u767b\u5834\uff01\r\n\u30fb\u65b0\u79f0\u53f7\u300c\u9ed9\u793a\u9332\u306e\u8987\u8005\u300d\u304c\u30ae\u30eb\u30c9\u30e9\u30f3\u30ad\u30f3\u30b0\u5831\u916c\u306b\u767b\u5834\uff01\r\n\u30fb\u65b0\u3075\u304d\u3060\u3057\u300c\u9ed9\u793a\u9332\u306e\u8987\u8005\u300d\u304c\u9ad8\u7d1a\u30ed\u30b0\u30a4\u30f3\u30dc\u30fc\u30ca\u30b9\u306b\u767b\u5834\uff01\r\n\r\n\u203b\u30a4\u30d9\u30f3\u30c8\u306f\u524d\u534a\u3068\u5f8c\u534a\u306b\u5206\u304b\u308c\u3066\u306e\u958b\u50ac\u3068\u306a\u308a\u307e\u3059\u3002\r\n\u203b\u524d\u534a\u304c\u300c8\u670812\u65e5\uff08\u706b\uff09-8\u670818\u65e5\uff08\u6708\uff09\u300d\u307e\u3067\u3001\u5f8c\u534a\u304c\u300c8\u670819\u65e5\uff08\u706b\uff09-8\u670825\u65e5\uff08\u6708\uff09\u300d\u307e\u3067\u958b\u50ac\u4e88\u5b9a\u3067\u3059\u3002\r\n\u203b\u524d\u534a\u30a4\u30d9\u30f3\u30c8\u3067\u4f7f\u7528\u3059\u308b\u4e00\u90e8\u30a2\u30a4\u30c6\u30e0\u306f\u5f8c\u534a\u30a4\u30d9\u30f3\u30c8\u3067\u4f7f\u7528\u3067\u304d\u307e\u305b\u3093\u306e\u3067\u3001\u671f\u9593\u4e2d\u306b\u4f7f\u7528\u3057\u3066\u304f\u3060\u3055\u3044\u3002\r\n\r\n\u3010\u6a5f\u80fd\u8abf\u6574\u3011\r\n\u30fb\u671f\u9593\u9650\u5b9aUI\u3092\u6700\u9069\u5316\r\n\u30fb\u30b3\u30e9\u30dc\u671f\u9593\u4e2d\u306e\u521d\u56de\u30c1\u30e3\u30fc\u30b8\u5831\u916c\u3092\u300c\u30e6\u30a8\u300d\u3068\u300c\u6bd2\u5cf6\u51b4\u5b50\u300d\u304b\u3089\u9078\u629e\u53ef\u80fd\u306b\u5909\u66f4\r\n\r\n\u3010\u4e0d\u5177\u5408\u4fee\u6b63\u3011\r\n\u30fb\u30d5\u30ec\u30f3\u30c9\u6570\u304c\u4e0a\u9650\u672a\u6e80\u3067\u3082\u8ffd\u52a0\u3067\u304d\u306a\u3044\u4e0d\u5177\u5408\u3092\u4fee\u6b63\r\n\u30fb\u63a2\u691c\u6226\u95d8\u4e2d\u306b\u30d5\u30ea\u30fc\u30ba\u3059\u308b\u4e0d\u5177\u5408\u3092\u4fee\u6b63\r\n\u30fb\u300c\u9b54\u7363\u6226\u4e89\u300d\u306b\u304a\u3044\u3066\u300c\u56db\u773c\u72fc\u300d\u306e\u56de\u5fa9\u52b9\u679c\u304c\u767a\u52d5\u3057\u306a\u3044\u4e0d\u5177\u5408\u3092\u4fee\u6b63\r\n\u30fb\u300c\u653b\u57ce\u6226\u300d\u3067\u540c\u3058\u30ae\u30eb\u30c9\u304c\u91cd\u8907\u8868\u793a\u3055\u308c\u308b\u4e0d\u5177\u5408\u3092\u4fee\u6b63\r\n\u30fb\u300c\u9b54\u57df\u7af6\u6280\u5834\u300d\u306e\u8868\u793a\u4e0d\u5177\u5408\u3092\u4fee\u6b63\r\n\r\n\u4eca\u5f8c\u3082\u3088\u308a\u5feb\u9069\u306b\u304a\u697d\u3057\u307f\u3044\u305f\u3060\u3051\u308b\u3088\u3046\u3001\u904b\u55b6\u30c1\u30fc\u30e0\u4e00\u540c\u52aa\u3081\u3066\u307e\u3044\u308a\u307e\u3059\u3002\u5f15\u304d\u7d9a\u304d\u3069\u3046\u305e\u3088\u308d\u3057\u304f\u304a\u9858\u3044\u3044\u305f\u3057\u307e\u3059\u3002","ko":"8\uc6d4 11\uc77c(\uc6d4) \uc5c5\ub370\uc774\ud2b8\ub97c \uc9c4\ud589\ud558\uc600\uc2b5\ub2c8\ub2e4. \uc5c5\ub370\uc774\ud2b8 \ub0b4\uc6a9\uc740 \ub2e4\uc74c\uacfc \uac19\uc2b5\ub2c8\ub2e4.\r\n\u3010\uc2e0\uaddc \uc774\ubca4\ud2b8\u3011\r\n\u300e\ud559\uc6d0\ubb35\uc2dc\ub85d HIGH  SCHOOL OF THE DEAD\u300f \ucf5c\ub77c\ubcf4 \uc774\ubca4\ud2b8 \uc804\ud3b8 \uac1c\ucd5c!\r\n\r\n\u30fb\uc2e0\uaddc \ucf5c\ub77c\ubcf4 \uc8fc\uc778\uacf5 \u2018\ubbf8\uc57c\ubaa8\ud1a0 \ub808\uc774\u2019 \ub4f1\uc7a5!\u3000\ud68d\ub4dd \uc2dc \ub098\uad6c\ubaa8 \ud558\uc9c0\uba54\uc640 \uc8fc\uc778\uacf5\uc744 \uad50\uccb4\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.\r\n\u30fb\uc2e0\uaddc \ub9c8\uc218 \u2018\ucf5c\ub77c\ubcf4 \ub9c8\uc218 \uc9c0\ud06c\u2019(SSR\/UR\/UR+) \uc774\ubca4\ud2b8 \ub4f1\uc7a5!\r\n\u30fb\uc2e0\uaddc \ub3d9\ub8cc \u2018\ubd80\uc2a4\uc9c0\ub9c8 \uc0ac\uc5d0\ucf54\u2019\uac00 \ucd94\ucca8\uc5d0 \ub4f1\uc7a5!\r\n\u30fb\uc2e0\uaddc \ub9c8\ubc95\uc9c4 \u2018\uc880\ube44 \ub9c8\ubc95\uc9c4\u2019\uc774 \ucd94\ucca8\uc5d0 \ub4f1\uc7a5!\r\n\u30fb\uc2e0\uaddc \uc2a4\ud0a8 \u2018\ubd80\uc2a4\uc9c0\ub9c8 \uc0ac\uc5d0\ucf54 - \uc218\uc601\ubcf5\u2019\uc774 \ud37c\uc990 \uc774\ubca4\ud2b8\uc5d0 \ub4f1\uc7a5!\r\n\u30fb\uc2e0\uaddc \uc544\ud2f0\ud329\ud2b8 \u2018\uc804\ub3d9 \ub4dc\ub9b4\u2019\uc774 \ucd94\ucca8\uc5d0 \ub4f1\uc7a5!\r\n\u30fb\uc2e0\uaddc \ud504\ub808\uc784 \u2018\ucd5c\uace0\uc758 \ub3c4\uac80\u2019\uc774 \uc721\uc131 \ud328\ud0a4\uc9c0\uc5d0 \ub4f1\uc7a5!\r\n\u30fb\uc2e0\uaddc \uce6d\ud638 \u2018\ucd5c\uace0\uc758 \ub3c4\uac80\u2019\uc774 \uc721\uc131 \ud328\ud0a4\uc9c0\uc5d0 \ub4f1\uc7a5!\r\n\u30fb\uc2e0\uaddc \ub9d0\ud48d\uc120 \u2018\ucd5c\uace0\uc758 \ub3c4\uac80\u2019\uc774 \ud328\uc2a4 \ubcf4\uc0c1\uc5d0 \ub4f1\uc7a5!\r\n\u30fb\uc2e0\uaddc \ud504\ub808\uc784 \u2018\ubb35\uc2dc\ub85d\uc758 \ud328\uad8c\uc790\u2019\uac00 \uac1c\uc778 \ub7ad\ud0b9 \ubcf4\uc0c1\uc5d0 \ub4f1\uc7a5!\r\n\u30fb\uc2e0\uaddc \uce6d\ud638 \u2018\ubb35\uc2dc\ub85d\uc758 \ud328\uad8c\uc790\u2019\uac00 \uae38\ub4dc \ub7ad\ud0b9 \ubcf4\uc0c1\uc5d0 \ub4f1\uc7a5!\r\n\u30fb\uc2e0\uaddc \ub9d0\ud48d\uc120 \u2018\ubb35\uc2dc\ub85d\uc758 \ud328\uad8c\uc790\u2019\uac00 \uace0\uae09 \ub85c\uadf8\uc778 \ubcf4\ub108\uc2a4\uc5d0 \ub4f1\uc7a5!\r\n\r\n\u203b\uc774\ubca4\ud2b8\ub294 \uc804\ud3b8\uacfc \ud6c4\ud3b8\uc73c\ub85c \ub098\ub204\uc5b4 \uc9c4\ud589\ub429\ub2c8\ub2e4.\r\n\u203b\uc804\ud3b8: 8\uc6d4 12\uc77c(\ud654)\\~8\uc6d4 18\uc77c(\uc6d4) \/ \ud6c4\ud3b8: 8\uc6d4 19\uc77c(\ud654)\\~8\uc6d4 25\uc77c(\uc6d4) \uc608\uc815\uc785\ub2c8\ub2e4.\r\n\u203b\uc804\ud3b8\uc5d0\uc11c \uc0ac\uc6a9\ud558\ub294 \uc77c\ubd80 \uc544\uc774\ud15c\uc740 \ud6c4\ud3b8\uc5d0\uc11c \uc0ac\uc6a9\ud560 \uc218 \uc5c6\uc73c\ub2c8 \uae30\uac04 \ub0b4\uc5d0 \uc0ac\uc6a9\ud558\uc2dc\uae30 \ubc14\ub78d\ub2c8\ub2e4.\r\n\r\n\u3010\uae30\ub2a5 \uc870\uc815\u3011\r\n\u30fb\uae30\uac04 \ud55c\uc815 UI \ucd5c\uc801\ud654\r\n\u30fb\ucf5c\ub77c\ubcf4 \uae30\uac04 \ub3d9\uc548 \uccab \ucda9\uc804 \ubcf4\uc0c1\uc744 \u2018\uc720\uc5d0\u2019 \ub610\ub294 \u2018\ubd80\uc2a4\uc9c0\ub9c8 \uc0ac\uc5d0\ucf54\u2019 \uc911 \uc120\ud0dd \uac00\ub2a5\ud558\ub3c4\ub85d \ubcc0\uacbd\r\n\r\n\u3010\uc624\ub958 \uc218\uc815\u3011\r\n\u30fb\uce5c\uad6c \uc218\uac00 \ud55c\ub3c4 \ubbf8\ub9cc\uc774\uc5b4\ub3c4 \ucd94\uac00\ud560 \uc218 \uc5c6\ub294 \uc624\ub958 \uc218\uc815\r\n\u30fb\ud0d0\ud5d8 \uc804\ud22c \uc911 \ud504\ub9ac\uc9d5 \uc624\ub958 \uc218\uc815\r\n\u30fb\u2018\ub9c8\uc218 \uc804\uc7c1\u2019\uc5d0\uc11c \u2018\uc0ac\uc548\ub791\u2019 \ud68c\ubcf5 \ud6a8\uacfc\uac00 \ubc1c\ub3d9\ud558\uc9c0 \uc54a\ub294 \uc624\ub958 \uc218\uc815\r\n\u30fb\u2018\uacf5\uc131\uc804\u2019\uc5d0\uc11c \ub3d9\uc77c \uae38\ub4dc\uac00 \uc911\ubcf5 \ud45c\uc2dc\ub418\ub294 \uc624\ub958 \uc218\uc815\r\n\u30fb\u2018\ub9c8\uc5ed \uacbd\uae30\uc7a5\u2019 \ud45c\uc2dc \uc624\ub958 \uc218\uc815\r\n\r\n\uc55e\uc73c\ub85c\ub3c4 \ucf8c\uc801\ud558\uac8c \uc990\uae30\uc2e4 \uc218 \uc788\ub3c4\ub85d \ucd5c\uc120\uc744 \ub2e4\ud558\uaca0\uc2b5\ub2c8\ub2e4. \uacc4\uc18d\ud574\uc11c \ub9ce\uc740 \uad00\uc2ec \ubd80\ud0c1\ub4dc\ub9bd\ub2c8\ub2e4.","en":"The update on August 11 (Mon) has been completed. Details are as follows:\r\n\u3010New Event\u3011\r\nPart 1 of the collaboration event with \"HIGH SCHOOL OF THE DEAD\" is now live!\r\n\r\n\u30fbNew collaboration protagonist \"Rei Miyamoto\" is here! Obtaining her allows you to switch between Hajime Nagumo and the protagonist.\r\n\u30fbNew Beast \"Collab Beast Zeke\" (SSR\/UR\/UR+) available in the event!\r\n\u30fbNew Hero \"Saeko Busujima\" available in Gacha!\r\n\u30fbNew Magic Circle \"Zombie Magic Circle\" available in Gacha!\r\n\u30fbNew Skin \"Saeko Busujima - Swimsuit\" available in Puzzle Event!\r\n\u30fbNew Artifact \"Electric Drill\" available in Gacha!\r\n\u30fbNew Frame \"Supreme Sword\" available in Growth Pack!\r\n\u30fbNew Title \"Supreme Sword\" available in Growth Pack!\r\n\u30fbNew Chat Bubble \"Supreme Sword\" available as Pass reward!\r\n\u30fbNew Frame \"Apocalypse Ruler\" available as Personal Ranking reward!\r\n\u30fbNew Title \"Apocalypse Ruler\" available as Guild Ranking reward!\r\n\u30fbNew Chat Bubble \"Apocalypse Ruler\" available as Adv. Login reward!\r\n\r\n\u203bThe event is divided into Part 1 and Part 2.\r\n\u203bPart 1: Aug 12 (Tue) - Aug 18 (Mon) \/ Part 2: Aug 19 (Tue) - Aug 25 (Mon)\r\n\u203bSome items from Part 1 cannot be used in Part 2. Please use them within the event period.\r\n\r\n\u3010Adjustments\u3011\r\n\u30fbLimited-time UI optimization\r\n\u30fbFirst Top-UP reward during the collaboration can now be chosen between \"Yue\" and \"Saeko Busujima\"\r\n\r\n\u3010Bug Fixes\u3011\r\n\u30fbFixed an issue where friends could not be added despite not reaching the limit!\r\n\u30fbFixed an issue where the game could freeze during Exploration battles!\r\n\u30fbFixed an issue where the \"Four-Eyed Wolf\" healing effect did not trigger in \u201cWar of Beasts\u201d!\r\n\u30fbFixed an issue where the same guild appeared twice in \u201cSiege Battle\u201d!\r\n\u30fbFixed a display issue in \u201cAbyss Arena\u201d!\r\n\r\nWe will continue to work hard to improve your gaming experience. Thank you for your continued support!\r\n\r\n","zh-TW":"8\u670811\u65e5\uff08\u661f\u671f\u4e00\uff09\u6211\u5011\u9032\u884c\u4e86\u7248\u672c\u66f4\u65b0\u3002\u66f4\u65b0\u5167\u5bb9\u5982\u4e0b\uff1a\r\n\u3010\u65b0\u6d3b\u52d5\u3011\r\n\u300a\u5b78\u5712\u9ed8\u793a\u9304 HIGH SCHOOL OF THE DEAD\u300b\u806f\u52d5\u6d3b\u52d5\u524d\u7bc7\u958b\u555f\uff01\r\n\r\n\u30fb\u65b0\u589e\u806f\u52d5\u4e3b\u89d2\u300c\u5bae\u672c\u9e97\u300d\u767b\u5834\uff01\u3000\u7372\u53d6\u5f8c\u53ef\u5207\u63db\u8207\u5357\u96f2\u59cb\u7684\u4e3b\u89d2\u9020\u578b\u3002\r\n\u30fb\u65b0\u589e\u9b54\u7378\u300c\u806f\u52d5\u9b54\u7378\u5409\u514b\u300d\uff08SSR\/UR\/UR+\uff09\uff0c\u53ef\u65bc\u6d3b\u52d5\u4e2d\u7372\u5f97\uff01\r\n\u30fb\u65b0\u589e\u82f1\u96c4\u300c\u6bd2\u5cf6\u51b4\u5b50\u300d\uff0c\u53ef\u65bc\u3010\u62bd\u734e\u3011\u4e2d\u7372\u5f97\uff01\r\n\u30fb\u65b0\u589e\u9b54\u6cd5\u9663\u300c\u6bad\u5c4d\u9b54\u6cd5\u9663\u300d\uff0c\u53ef\u65bc\u3010\u62bd\u734e\u3011\u4e2d\u7372\u5f97\uff01\r\n\u30fb\u65b0\u589e\u9020\u578b\u300c\u6bd2\u5cf6\u51b4\u5b50 - \u6cf3\u88dd\u300d\uff0c\u53ef\u65bc\u3010\u62fc\u5716\u3011\u4e2d\u7372\u5f97\uff01\r\n\u30fb\u65b0\u589e\u795e\u5668\u300c\u96fb\u947d\u300d\uff0c\u53ef\u65bc\u3010\u62bd\u734e\u3011\u4e2d\u7372\u5f97\uff01\r\n\u30fb\u65b0\u589e\u982d\u50cf\u6846\u300c\u81f3\u9ad8\u7684\u5200\u528d\u300d\uff0c\u53ef\u65bc\u3010\u990a\u6210\u79ae\u5305\u3011\u4e2d\u7372\u5f97\uff01\r\n\u30fb\u65b0\u589e\u7a31\u865f\u300c\u81f3\u9ad8\u7684\u5200\u528d\u300d\uff0c\u53ef\u65bc\u3010\u990a\u6210\u79ae\u5305\u3011\u4e2d\u7372\u5f97\uff01\r\n\u30fb\u65b0\u589e\u5c0d\u8a71\u6846\u300c\u81f3\u9ad8\u7684\u5200\u528d\u300d\uff0c\u53ef\u65bc\u3010\u6230\u4ee4\u3011\u4e2d\u7372\u5f97\uff01\r\n\u30fb\u65b0\u589e\u982d\u50cf\u6846\u300c\u9ed8\u793a\u9304\u7684\u9738\u8005\u300d\uff0c\u53ef\u65bc\u3010\u500b\u4eba\u6392\u884c\u699c\u3011\u4e2d\u7372\u5f97\uff01\r\n\u30fb\u65b0\u589e\u7a31\u865f\u300c\u9ed8\u793a\u9304\u7684\u9738\u8005\u300d\uff0c\u53ef\u65bc\u3010\u516c\u6703\u6392\u884c\u699c\u3011\u4e2d\u7372\u5f97\uff01\r\n\u30fb\u65b0\u589e\u5c0d\u8a71\u6846\u300c\u9ed8\u793a\u9304\u7684\u9738\u8005\u300d\uff0c\u53ef\u65bc\u3010\u9ad8\u7d1a\u7c3d\u5230\u3011\u4e2d\u7372\u5f97\uff01\r\n\r\n\u203b\u6d3b\u52d5\u5206\u70ba\u524d\u7bc7\u8207\u5f8c\u7bc7\u8209\u884c\u3002\r\n\u203b\u524d\u7bc7\uff1a8\u670812\u65e5\uff08\u661f\u671f\u4e8c\uff09\\~ 8\u670818\u65e5\uff08\u661f\u671f\u4e00\uff09 \/ \u5f8c\u7bc7\uff1a8\u670819\u65e5\uff08\u661f\u671f\u4e8c\uff09\\~ 8\u670825\u65e5\uff08\u661f\u671f\u4e00\uff09\r\n\u203b\u524d\u7bc7\u6d3b\u52d5\u4f7f\u7528\u7684\u90e8\u5206\u9053\u5177\u7121\u6cd5\u5728\u5f8c\u7bc7\u4f7f\u7528\uff0c\u8acb\u65bc\u6d3b\u52d5\u671f\u9593\u5167\u4f7f\u7528\u5b8c\u7562\u3002\r\n\r\n\u3010\u529f\u80fd\u8abf\u6574\u3011\r\n\u30fb\u9650\u6642\u4ecb\u9762\u512a\u5316\r\n\u30fb\u806f\u52d5\u671f\u9593\u9996\u5132\u734e\u52f5\u53ef\u65bc\u300c\u6708\u300d\u8207\u300c\u6bd2\u5cf6\u51b4\u5b50\u300d\u4e2d\u64c7\u4e00\r\n\r\n\u3010\u554f\u984c\u4fee\u5fa9\u3011\r\